NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swisskit
WEB_APP_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080
AUTH_COOKIE_NAME=swisskit_auth
AUTH_COOKIE_SAME_SITE=lax
# Em deploy com frontend/API em origens diferentes, use:
# AUTH_COOKIE_SAME_SITE=none
# NODE_ENV=production

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

JWT_SECRET=replace-with-a-long-random-string
# Use duração positiva com unidade (ex: 1d, 12h, 30m) ou segundos inteiros (ex: 86400)
JWT_EXPIRES_IN=1d
