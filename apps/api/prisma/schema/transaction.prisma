model Transaction {
  id            String          @id @default(uuid())
  userId        String
  accountId     String
  categoryId    String
  subcategoryId String?
  type          TransactionType
  amountCents   Int
  note          String?
  isInstallment Boolean         @default(false)
  installmentNumber Int?
  installmentTotal Int?
  installmentGroupId String?
  occurredAt    DateTime
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account         @relation("AccountTransactions", fields: [accountId, userId], references: [id, userId], onDelete: Restrict)
  category      Category        @relation("CategoryTransactions", fields: [categoryId, userId], references: [id, userId], onDelete: Restrict)
  subcategory   Subcategory?    @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([userId, type])
  @@index([userId, installmentGroupId])
  @@index([accountId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@unique([id, userId])
}
