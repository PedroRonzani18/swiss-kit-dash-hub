{
  "name": "swiss-kit-dash-hub",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node ./scripts/run-web-workspace.mjs dev",
    "build": "node ./scripts/run-web-workspace.mjs build",
    "build:ci": "pnpm build:api && pnpm build:web",
    "build:dev": "node ./scripts/run-web-workspace.mjs build:dev",
    "lint": "node ./scripts/run-web-workspace.mjs lint",
    "lint:ci": "pnpm lint:api && pnpm lint:web",
    "preview": "node ./scripts/run-web-workspace.mjs preview",
    "test": "node ./scripts/run-web-workspace.mjs test",
    "test:ci": "pnpm test:api && pnpm test:web",
    "test:watch": "node ./scripts/run-web-workspace.mjs test:watch",
    "typecheck": "pnpm typecheck:api && pnpm typecheck:web",
    "typecheck:api": "pnpm --filter api typecheck",
    "typecheck:web": "pnpm --filter web exec tsc -b",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "test:web": "pnpm --filter web test",
    "test:api": "pnpm --filter api test",
    "lint:web": "pnpm --filter web lint",
    "lint:api": "pnpm --filter api lint"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
