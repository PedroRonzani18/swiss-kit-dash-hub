{
  "name": "swiss-kit-dash-hub",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:ci": "pnpm build",
    "lint": "turbo run lint",
    "lint:ci": "pnpm lint",
    "test": "turbo run test",
    "test:ci": "pnpm test",
    "typecheck": "turbo run typecheck",
    "typecheck:api": "pnpm --filter api typecheck",
    "typecheck:web": "pnpm --filter web typecheck",
    "dev": "turbo run dev --filter=api --filter=web",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build:web": "pnpm --filter web build",
    "build:web:dev": "pnpm --filter web build:dev",
    "build:api": "pnpm --filter api build",
    "preview:web": "pnpm --filter web preview",
    "test:web": "pnpm --filter web test",
    "test:web:e2e": "pnpm --filter web test:e2e",
    "test:web:watch": "pnpm --filter web test:watch",
    "test:api": "pnpm --filter api test",
    "lint:web": "pnpm --filter web lint",
    "lint:api": "pnpm --filter api lint"
  },
  "devDependencies": {
    "turbo": "^2.9.5"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
