{
  "name": "swiss-kit-dash-hub",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node ./scripts/run-web-workspace.mjs dev",
    "build": "turbo run build",
    "build:ci": "pnpm build",
    "build:dev": "node ./scripts/run-web-workspace.mjs build:dev",
    "lint": "turbo run lint",
    "lint:ci": "pnpm lint",
    "preview": "node ./scripts/run-web-workspace.mjs preview",
    "test": "turbo run test",
    "test:ci": "pnpm test",
    "test:watch": "node ./scripts/run-web-workspace.mjs test:watch",
    "typecheck": "turbo run typecheck",
    "typecheck:api": "turbo run typecheck --filter=api",
    "typecheck:web": "turbo run typecheck --filter=web",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=api",
    "test:web": "turbo run test --filter=web",
    "test:api": "turbo run test --filter=api",
    "lint:web": "turbo run lint --filter=web",
    "lint:api": "turbo run lint --filter=api"
  },
  "devDependencies": {
    "turbo": "^2.9.5"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
